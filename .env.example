# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=debug
TEST_BASE_URL=http://hltv-api:8000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMITING_ENABLE=False
RATE_LIMITING_FREQUENCY=2/3seconds

# ── FlareSolverr ──────────────────────────────────────────────────────────────
# Local dev: localhost / Docker: flaresolverr
FLARESOLVERR_HOST=localhost
FLARESOLVERR_PORT=8191
FLARESOLVERR_IMAGE_VERSION=latest
FLARESOLVERR_LOG_LEVEL=info
FLARESOLVERR_CAPTCHA_SOLVING=false
FLARESOLVERR_BROWSER_TIMEOUT=60000